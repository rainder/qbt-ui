# Copy to .env and adjust.

# Host port mappings
WEB_PORT=8080      # qbt-ui (this app)
QBT_PORT=8888      # qBittorrent classic WebUI (rarely needed)
BT_PORT=6881       # BitTorrent listen port (TCP + UDP)

# User / group IDs the linuxserver/qbittorrent container runs as.
# Match your host user so downloaded files have sensible ownership.
PUID=1000
PGID=1000
TZ=Etc/UTC

# Persistent data on the host. Default to ./data which the compose
# project will create if missing.
CONFIG_DIR=./data/config
DOWNLOADS_DIR=./data/downloads
