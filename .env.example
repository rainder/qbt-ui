# Copy to .env and adjust.
# Used by: docker-compose.yml (compose) and `npm run dev` (Vite picks up QBT_URL).

# ─── Host ports ─────────────────────────────────────────────────────────────
WEB_PORT=8080            # qbt-ui — open this in your browser
QBT_PORT=8888            # qBittorrent classic WebUI (rarely needed)
BT_PORT=6881             # BitTorrent listen port (TCP + UDP)

# ─── Backend URL ────────────────────────────────────────────────────────────
# What the qbt-ui nginx proxies /api/* to.
# Default points at the bundled qBittorrent service inside the compose
# network. Override to point at an existing qBittorrent instance.
QBT_BACKEND=http://qbittorrent:8080
# Examples:
#   QBT_BACKEND=http://192.168.1.2:8080
#   QBT_BACKEND=http://host.docker.internal:8080   # qB on the host

# ─── Dev server only (npm run dev) ──────────────────────────────────────────
# Vite reads this and proxies /api to it. Ignored by the Docker image.
QBT_URL=http://localhost:8080

# ─── qBittorrent container identity ────────────────────────────────────────
# linuxserver/qbittorrent runs as this user/group. Match your host user
# so downloaded files have sensible ownership.
PUID=1000
PGID=1000
TZ=Etc/UTC

# ─── Persistent paths on the host ───────────────────────────────────────────
# The compose project will create ./data if it doesn't exist.
CONFIG_DIR=./data/config
DOWNLOADS_DIR=./data/downloads
